# Example BBS configuration — copy to bbs.yaml and edit before running

bbs:
  # Your station callsign (max 6 chars) and SSID (0-15)
  callsign: "N0CALL"
  ssid: 1
  # Displayed in the login banner
  name: "My Amateur Radio BBS"
  sysop: "N0CALL"
  location: "Anytown, USA"
  # Maximum concurrent connected users (0 = unlimited)
  max_users: 20
  # Idle timeout in seconds before disconnecting a user (0 = disabled)
  idle_timeout: 300

transports:
  # Enable one or more transports. The BBS listens on all enabled transports simultaneously.

  # KISS over serial port (Dire Wolf /dev/ttyACM0 or hardware TNC)
  kiss_serial:
    enabled: false
    device: "/dev/ttyACM0"
    baud: 9600
    # AX.25 port number inside KISS frames (0-15)
    port: 0

  # KISS over TCP socket (Dire Wolf default: 8001)
  kiss_tcp:
    enabled: true
    host: "127.0.0.1"
    port: 8001
    # AX.25 port number inside KISS frames (0-15)
    ax25_port: 0

  # Linux kernel AX.25 (AF_AX25 sockets via axports / kissattach)
  kernel_ax25:
    enabled: false
    # axport name from /etc/ax25/axports
    axport: "ax0"
    beacon_text: "W6ELA-5 BBS - Palo Alto"
    beacon_interval: 20
    beacon_path: ""   # e.g. "WIDE1-1,WIDE2-1" or "KD6XYZ-3,W6ABC"

  # AGWPE / AGW Packet Engine (SV2AGW) TCP API — connects to a running AGWPE or
  # compatible engine (e.g. Direwolf with AGW interface, UZ7HO Soundmodem).
  agwpe:
    enabled: false
    host: "127.0.0.1"
    # AGWPE default TCP port is 8000
    port: 8000
    # Radio port number inside AGWPE (0-based)
    agw_port: 0
    # Leave blank if AGWPE has no password set
    password: ""
    beacon_text: ""
    beacon_dest: "BEACON"
    beacon_interval: 20   # minutes
    beacon_path: ""       # e.g. "WIDE1-1,WIDE2-1"

  # Plain TCP (for Telnet / local testing)
  tcp:
    enabled: true
    host: "0.0.0.0"
    port: 6300

database:
  # Path to SQLite database file
  path: "data/bbs.db"
  # Number of days to keep connection journal entries (0 = keep forever)
  connection_log_days: 30

auth:
  # HMAC-SHA256 challenge-response: shared secret set per-user via web interface.
  # Most features are accessible with just a callsign (which is carried in the AX.25
  # connection); HMAC auth unlocks privileged operations (post, settings change, etc.)
  # Nonce length in hex characters (must be even; 32 = 16 bytes of entropy)
  nonce_hex_length: 32
  # Failed auth attempts before lockout
  max_attempts: 3
  # Lockout duration in seconds
  lockout_seconds: 900

plugins:
  bulletins:
    enabled: true
    # Maximum message body size in bytes (keep small for 1200bps)
    max_body_bytes: 4096
    # Maximum subject length in characters
    max_subject_chars: 25
    # Default areas created on first run
    default_areas:
      - { name: "GENERAL", description: "General discussion" }
      - { name: "TECH",    description: "Technical topics" }
      - { name: "DX",      description: "DX news and reports" }

  chat:
    enabled: true
    # Lines of history kept in memory per room
    history_lines: 20
    # Default rooms created on first run
    default_rooms:
      - { name: "main", description: "Main chat room" }

  lastconn:
    enabled: true
    # Maximum rows shown in the plugin listing
    limit: 200

  info:
    enabled: true
    # Optional seed message – used only when the database row is still empty.
    # Once the sysop edits the message via the web UI this value is ignored.
    message: ""

  heard:
    enabled: true
    # Maximum rows shown in the listing
    limit: 200

web:
  host: "127.0.0.1"
  port: 8080
  # Change this before first run! (used for sysop web login only)
  # The HMAC secrets for radio users are set separately per-user.
  sysop_password_hash: ""   # leave blank; set via: bbs2 --set-sysop-password
  # Secret key for Flask sessions — replace with a random string
  secret_key: "CHANGE_ME_BEFORE_RUNNING"

logging:
  level: "INFO"     # DEBUG, INFO, WARNING, ERROR
  # Optional file path; leave blank to log to stdout only
  file: ""
